---
import BackroomsBackground from '../components/BackroomsBackground.astro';
import PanelToggle from '../components/PanelToggle.astro';
import { defaultLang, t } from '../i18n';
import '../styles/global.css';

interface Props {
	description?: string;
}

const lang = defaultLang;
const { description = t(lang, 'meta.description') } = Astro.props;
const siteTitle = 'rasxcore';

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(`${import.meta.env.BASE_URL}og-image.png`, Astro.site);
---

<!doctype html>
<html lang={lang} data-panel-theme="wall">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} data-i18n="meta.description" />
		<meta name="theme-color" content="#c4a24a" />
		<meta name="author" content="rasxcore" />

		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={siteTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={siteTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} sizes="48x48" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="canonical" href={canonicalURL} />

		<title>{siteTitle}</title>
		<script is:inline>
			(function () {
				var lang = localStorage.getItem('lang');
				if (lang !== 'en' && lang !== 'ru') {
					var list =
						navigator.languages && navigator.languages.length
							? navigator.languages
							: [navigator.language || 'en'];
					lang = 'en';
					for (var i = 0; i < list.length; i++) {
						var locale = String(list[i]).toLowerCase();
						if (locale.indexOf('ru') === 0) {
							lang = 'ru';
							break;
						}
						if (locale.indexOf('en') === 0) {
							lang = 'en';
							break;
						}
					}
				}
				document.documentElement.lang = lang;

				var theme = localStorage.getItem('panel-theme');
				if (theme === 'wall' || theme === 'corridor' || theme === 'fluoro') {
					document.documentElement.setAttribute('data-panel-theme', theme);
				}
			})();
		</script>
	</head>
	<body>
		<BackroomsBackground />
		<div
			class="relative z-[2] flex min-h-dvh flex-col items-center px-4 pb-10 pt-6 sm:px-6 sm:pb-12 sm:pt-10"
		>
			<div
				id="content-panel"
				class="panel-frame relative z-[2] w-full max-w-[calc(var(--width-content)+3rem)] rounded-[20px] border-[3px] p-3 sm:p-5"
			>
				<PanelToggle />
				<div id="content-panel-body">
					<main class="mx-auto w-full max-w-[var(--width-content)]">
						<slot />
					</main>
				</div>
			</div>
		</div>
		<script>
			import { initSiteClient } from '../scripts/i18n-client.ts';

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', initSiteClient);
			} else {
				initSiteClient();
			}
		</script>
	</body>
</html>
